# SiliconFlow API key (required)
LLM_API_KEY=sk-your-siliconflow-key-here

# --- Image generation (creative mode) ---
# IMAGE_API_KEY defaults to LLM_API_KEY if not set
# IMAGE_API_KEY=sk-your-image-api-key-here
IMAGE_API_URL=https://api.siliconflow.cn/v1/images/generations
IMAGE_MODEL=Qwen/Qwen-Image

# --- Server ---
PORT=3001
